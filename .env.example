# Copy to .env for local development. On Vercel, add these in
# Project -> Settings -> Environment Variables (and redeploy).

# Anthropic: https://console.anthropic.com -> API Keys (profile generation)
ANTHROPIC_API_KEY=

# Google AI Studio: https://aistudio.google.com -> Get API key (follow-up questions)
GEMINI_API_KEY=

# Supabase: Dashboard -> Project Settings -> Data API -> Project URL
SUPABASE_URL=
# Supabase: Dashboard -> Project Settings -> API Keys -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Telegram: @BotFather -> /mybots -> your bot -> API Token
TELEGRAM_BOT_TOKEN=

# Model overrides (optional)
CLAUDE_MODEL=claude-haiku-4-5
# GEMINI_MODEL=gemini-2.5-flash

# LOCAL DEV ONLY: accept requests without valid Telegram initData.
# NEVER set this on Vercel.
# ALLOW_FAKE_AUTH=1
